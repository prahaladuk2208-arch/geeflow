// ============================================================
// TRAINING POLYGON COLLECTOR — {{ year }} ({{ sensor_label }})
// Generated by lulc-engine for project: {{ project_name }}
// ============================================================
// Paste this ENTIRE script into: https://code.earthengine.google.com/
//
// Workflow:
//   1. In the Geometry Imports panel, create one FeatureCollection per class,
//      named exactly as listed below, with property  {{ class_property }} = <code>:
{%- for c in classes %}
//        {{ c.var }}  ->  {{ class_property }} = {{ c.code }}   ({{ c.name }})
{%- endfor %}
//   2. Draw POLYGONS (not points) in homogeneous areas. 15-30 per class.
//   3. Uncomment the EXPORT block at the bottom and save the file as:
//        {{ filename }}
// ============================================================

// --- Study Area ---
{% if aoi_kind == 'center_buffer' -%}
var aoi = ee.Geometry.Point({{ lon }}, {{ lat }}).buffer({{ radius_m }});
{%- elif aoi_kind == 'ee_asset' -%}
var aoi = ee.FeatureCollection('{{ ee_asset }}').geometry();
{%- else -%}
var aoi = ee.Geometry({{ geojson_geometry }});
{%- endif %}
Map.centerObject(aoi, 11);
Map.addLayer(aoi, {color: 'red'}, 'Study Area Boundary');

// --- Cloud masking ---
{% if era_kind == 's2' -%}
function maskImage(image) {
  var scl = image.select('SCL');
  var mask = scl.neq(3).and(scl.neq(7)).and(scl.neq(8))
    .and(scl.neq(9)).and(scl.neq(10));
  return image.divide(10000).updateMask(mask)
    .copyProperties(image, ['system:time_start']);
}
{%- elif era_kind == 'mss' -%}
function maskImage(image) {
  var qa = image.select('QA_PIXEL');
  var mask = qa.bitwiseAnd(1 << 3).eq(0).and(qa.bitwiseAnd(1 << 4).eq(0));
  return ee.Algorithms.Landsat.TOA(image.updateMask(mask));
}
{%- else -%}
function maskImage(image) {
  var qa = image.select('QA_PIXEL');
  var mask = qa.bitwiseAnd(1 << 3).eq(0).and(qa.bitwiseAnd(1 << 4).eq(0));
  var optical = image.select('SR_B.').multiply(0.0000275).add(-0.2);
  return image.addBands(optical, null, true).updateMask(mask);
}
{%- endif %}

// --- Seasonal composites (harmonized band names) ---
{% for s in seasons -%}
var {{ s.var }} = ee.ImageCollection('{{ collection_id }}')
    .filterBounds(aoi).filterDate('{{ s.start }}', '{{ s.end }}')
    .map(maskImage).median().clip(aoi)
    .select({{ select_src }}, {{ select_dst }});
{% endfor %}
// --- Indices for visual guidance ---
var ndvi_ref = {{ ref_var }}.normalizedDifference(['NIR', 'Red']).rename('NDVI_ref');
{% if other_var -%}
var ndvi_other = {{ other_var }}.normalizedDifference(['NIR', 'Red']).rename('NDVI_other');
var delta_ndvi = ndvi_other.subtract(ndvi_ref).rename('delta_NDVI');
{%- endif %}
{% if has_swir -%}
var ndmi_ref = {{ ref_var }}.normalizedDifference(['NIR', 'SWIR1']).rename('NDMI_ref');
{%- endif %}

var allIndices = ndvi_ref{% if other_var %}.addBands(ndvi_other).addBands(delta_ndvi){% endif %}{% if has_swir %}.addBands(ndmi_ref){% endif %};

// ============================================================
// LIVE PIXEL INFO PANEL — click the map while deciding a label
// ============================================================
var infoPanel = ui.Panel({
  style: {
    position: 'bottom-left', padding: '8px 12px',
    backgroundColor: 'rgba(255,255,255,0.9)',
    border: '1px solid #999', width: '280px'
  }
});
var infoLabel  = ui.Label('Click map to see pixel values',
  {fontSize: '13px', fontWeight: 'bold', margin: '0 0 4px 0'});
var ndviLabel  = ui.Label('NDVI ({{ ref_name }}): --');
{% if other_var -%}
var deltaLabel = ui.Label('delta NDVI ({{ other_name }} - {{ ref_name }}): --');
{%- endif %}
{% if has_swir -%}
var ndmiLabel  = ui.Label('NDMI ({{ ref_name }}): --');
{%- endif %}
infoPanel.add(infoLabel).add(ndviLabel){% if other_var %}.add(deltaLabel){% endif %}{% if has_swir %}.add(ndmiLabel){% endif %};
Map.add(infoPanel);

Map.onClick(function(coords) {
  var point = ee.Geometry.Point(coords.lon, coords.lat);
  var values = allIndices.sample(point, {{ scale }}).first();
  values.evaluate(function(result) {
    if (!result || !result.properties) {
      ndviLabel.setValue('NDVI ({{ ref_name }}): no data');
      return;
    }
    var p = result.properties;
    ndviLabel.setValue('NDVI ({{ ref_name }}): ' +
      (p.NDVI_ref !== null ? p.NDVI_ref.toFixed(3) : '--'));
{%- if other_var %}
    deltaLabel.setValue('delta NDVI: ' +
      (p.delta_NDVI !== null ? p.delta_NDVI.toFixed(3) : '--'));
{%- endif %}
{%- if has_swir %}
    ndmiLabel.setValue('NDMI ({{ ref_name }}): ' +
      (p.NDMI_ref !== null ? p.NDMI_ref.toFixed(3) : '--'));
{%- endif %}
  });
});

// ============================================================
// MAP LAYERS
// ============================================================
Map.addLayer({{ ref_var }}, {bands: ['Red', 'Green', 'Blue'], min: 0, max: 0.3},
  'True Color ({{ ref_name }})');
Map.addLayer({{ ref_var }}, {bands: ['NIR', 'Red', 'Green'], min: 0, max: 0.4},
  'False Color NIR ({{ ref_name }})', false);
{% if has_swir -%}
Map.addLayer({{ ref_var }}, {bands: ['SWIR2', 'NIR', 'Red'], min: 0, max: 0.4},
  'SWIR-NIR-Red ({{ ref_name }})', false);
{%- endif %}
{% if other_var -%}
Map.addLayer({{ other_var }}, {bands: ['Red', 'Green', 'Blue'], min: 0, max: 0.3},
  'True Color ({{ other_name }})', false);
{%- endif %}
Map.addLayer(ndvi_ref, {min: -0.1, max: 0.8,
  palette: ['brown', 'yellow', 'green', 'darkgreen']}, 'NDVI ({{ ref_name }})', false);
{% if other_var -%}
Map.addLayer(delta_ndvi, {min: -0.1, max: 0.5, palette: ['blue', 'white', 'red']},
  'delta NDVI ({{ other_name }} - {{ ref_name }})', false);
{%- endif %}

